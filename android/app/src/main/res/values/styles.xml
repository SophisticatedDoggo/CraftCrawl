<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.TrailDark" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_trail_dark</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.Ember" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_ember</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.EmberDark" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_ember_dark</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.Riverstone" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_riverstone</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.RiverstoneDark" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_riverstone_dark</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.Blackberry" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_blackberry</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.BlackberryDark" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_blackberry_dark</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.Barnwood" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_barnwood</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.BarnwoodDark" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash_barnwood_dark</item>
    </style>
</resources>
