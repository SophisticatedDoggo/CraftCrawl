{
  "name": "craftcrawl-mobile-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor native shell for the hosted CraftCrawl PHP web app.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "cap:sync": "cap sync",
    "cap:sync:staging:android": "CRAFTCRAWL_APP_ENV=staging CRAFTCRAWL_MOBILE_URL=https://staging.craftcrawl.site cap sync android",
    "cap:sync:prod:android": "CRAFTCRAWL_APP_ENV=prod CRAFTCRAWL_MOBILE_URL=https://app.craftcrawl.site cap sync android",
    "cap:sync:prod:ios": "CRAFTCRAWL_APP_ENV=prod CRAFTCRAWL_MOBILE_URL=https://app.craftcrawl.site cap sync ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "assets:icons": "tools/generate-app-icons.sh",
    "assets:splash": "tools/generate-splash-assets.sh",
    "assets:native": "npm run assets:icons && npm run assets:splash",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:debug:staging": "cd android && ./gradlew assembleStagingDebug",
    "android:debug:prod": "cd android && ./gradlew assembleProdDebug",
    "mobile:doctor": "cap doctor"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  }
}
